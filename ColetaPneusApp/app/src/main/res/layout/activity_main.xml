<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_tela_inicial"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/texto_subtitulo"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btn_sou_cliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_sou_cliente"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_sou_prestador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_sou_prestador"
        android:textSize="18sp"/>

</LinearLayout>
